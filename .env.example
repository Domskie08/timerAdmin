APP_NAME=TimerAdmin
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Taipei

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=timer_admin
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

TIMER_ACTIVE_WINDOW_MINUTES=10
TIMER_UPDATE_UPLOAD_MAX_KB=204800
TIMER_PHILIPPINE_TIMEZONE=Asia/Manila
TIMER_PHILIPPINE_TIME_URL=https://worldtimeapi.org/api/timezone/Asia/Manila
TIMER_PHILIPPINE_TIME_TIMEOUT_SECONDS=3
